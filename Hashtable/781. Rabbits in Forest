class Solution {
    public int numRabbits(int[] ans) {
        HashMap<Integer,Integer> map = new HashMap<>();
        for(int val : ans) {
            map.put(val,map.getOrDefault(val,0)+1);
        }
        int ans1 = 0;
        for(int key: map.keySet()) {
            int  gs = key+1;
            int rep = map.get(key);
            int ng =(int) Math.ceil((rep*1.0)/gs*1.0);
            ans1 += gs*ng;
        }
        return ans1;
    }
}
