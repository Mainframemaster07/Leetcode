class Solution {
    /**
     * Given a sorted unique integer array, return the smallest sorted list of ranges
     * that cover all the numbers in the array exactly.
     * 
     * @param nums sorted unique integer array
     * @return list of string ranges in format "a->b" or "a"
     */
    public List<String> summaryRanges(int[] nums) {
        List<String> result = new ArrayList<>();
        int arrayLength = nums.length;
        for (int startIndex = 0; startIndex < arrayLength; ) {
            int endIndex = startIndex;
            while (endIndex + 1 < arrayLength && nums[endIndex + 1] == nums[endIndex] + 1) {
                endIndex++;
            }
            result.add(formatRange(nums, startIndex, endIndex));
            startIndex = endIndex + 1;
        }
      
        return result;
    }
  
    /**
     * Formats a range into string representation.
     * Single element: "a"
     * Multiple elements: "a->b"
     * 
     * @param nums the array containing the values
     * @param startIndex starting index of the range
     * @param endIndex ending index of the range
     * @return formatted string representation of the range
     */
    private String formatRange(int[] nums, int startIndex, int endIndex) {
        if (startIndex == endIndex) {
            return String.valueOf(nums[startIndex]);
        }
        return String.format("%d->%d", nums[startIndex], nums[endIndex]);
    }
}
